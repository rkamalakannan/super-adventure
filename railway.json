{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node dist/index.js",
    "restartPolicy": "always",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100
  },
  "env": {
    "PORT": {
      "description": "Port to run the backend server on",
      "value": "3001"
    },
    "JWT_SECRET": {
      "description": "JWT secret key for token signing",
      "value": ""
    },
    "DATABASE_URL": {
      "description": "PostgreSQL database URL (provided by Railway PostgreSQL plugin)",
      "value": ""
    },
    "SMTP_HOST": {
      "description": "SMTP server host for email notifications",
      "value": ""
    },
    "SMTP_PORT": {
      "description": "SMTP server port",
      "value": "587"
    },
    "SMTP_USER": {
      "description": "SMTP username",
      "value": ""
    },
    "SMTP_PASS": {
      "description": "SMTP password",
      "value": ""
    },
    "SMTP_FROM": {
      "description": "From email address",
      "value": "noreply@pricetracker.local"
    }
  },
  "plugins": [
    {
      "source": "railway/postgres",
      "config": {
        "POSTGRES_VERSION": "15"
      }
    }
  ]
}
